{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "ModelRoute",
  "colors": {
    "primary": "#6366F1",
    "light": "#818CF8",
    "dark": "#4F46E5"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "quickstart", "authentication"]
          },
          {
            "group": "Executions",
            "pages": ["executions/overview", "executions/sync", "executions/async"]
          },
          {
            "group": "Files",
            "pages": ["files/overview", "files/uploading", "files/downloading"]
          },
          {
            "group": "Webhooks",
            "pages": ["webhooks/overview", "webhooks/setup", "webhooks/verification"]
          },
          {
            "group": "Errors",
            "pages": ["errors/overview", "errors/error-codes"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "API Status",
          "href": "https://status.modelroute.ai",
          "icon": "signal"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@modelroute.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.modelroute.ai"
    }
  },
  "contextual": {
    "options": ["copy", "view", "claude", "cursor"]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/c5ks"
    }
  }
}
